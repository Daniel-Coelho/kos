generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  cpf              String          @unique
  name             String
  phone            String?
  nickname         String?
  password         String
  role             String          @default("USER")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  adminLogs        AdminLog[]
  participations   Participation[]
  transactions     Transaction[]
}

model Group {
  id             String          @id @default(cuid())
  name           String
  entryFee       Decimal
  stripePriceId  String?
  prizePool      Decimal         @default(0)
  status         String          @default("OPEN")
  participations Participation[]
}

model Participation {
  id             String   @id @default(cuid())
  userId         String
  groupId        String
  status         String   @default("ALIVE")
  errors         Int      @default(0)
  repescagemUsed Boolean  @default(false)
  joinedAt       DateTime @default(now())
  group          Group    @relation(fields: [groupId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
  picks          Pick[]
}

model Round {
  id       String   @id @default(cuid())
  number   Int
  deadline DateTime
  status   String   @default("SCHEDULED")
  matches  Match[]
  picks    Pick[]
}

model Match {
  id         String   @id @default(cuid())
  roundId    String
  homeTeam   String
  awayTeam   String
  homeScore  Int?
  awayScore  Int?
  result     String?
  startTime  DateTime
  homeClubId String?
  awayClubId String?
  stadium    String?
  awayClub   Club?    @relation("AwayMatch", fields: [awayClubId], references: [id])
  homeClub   Club?    @relation("HomeMatch", fields: [homeClubId], references: [id])
  round      Round    @relation(fields: [roundId], references: [id])
}

model Pick {
  id              String        @id @default(cuid())
  participationId String
  roundId         String
  team            String
  status          String        @default("PENDING")
  createdAt       DateTime      @default(now())
  participation   Participation @relation(fields: [participationId], references: [id])
  round           Round         @relation(fields: [roundId], references: [id])

  @@unique([participationId, roundId])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Decimal
  type      String
  status    String
  stripeId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Club {
  id          String   @id @default(cuid())
  name        String
  shortName   String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  awayMatches Match[]  @relation("AwayMatch")
  homeMatches Match[]  @relation("HomeMatch")
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
}
